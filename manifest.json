{
  "manifest_version": 3,
  "name": "Keepsake",
  "version": "1.4.0",
  "description": "Attach personal notes to moments in Spotify songs and share them as a link.",
  "homepage_url": "https://aishwaryachulaki.github.io/songnotes/index.html",
  "support_url": "https://aishwaryachulaki.github.io/songnotes/faq.html",
  "permissions": ["storage", "activeTab", "tabs", "sidePanel"],
  "host_permissions": [
    "https://open.spotify.com/*",
    "https://aishwaryachulaki.github.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Keepsake"
  },
  "icons": { "48": "icon.png", "128": "icon.png" },
  "web_accessible_resources": [
    {
      "resources": ["floater.png"],
      "matches": ["https://open.spotify.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://aishwaryachulaki.github.io/*/share.html*"],
      "js": ["share-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://aishwaryachulaki.github.io/*/auth.html*",
        "https://aishwaryachulaki.github.io/*/account.html*",
        "https://aishwaryachulaki.github.io/*/sent.html*",
        "https://aishwaryachulaki.github.io/*/received.html*",
        "https://aishwaryachulaki.github.io/*/notes.html*"
      ],
      "js": ["auth-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://aishwaryachulaki.github.io/*/notes.html*"],
      "js": ["notes-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
